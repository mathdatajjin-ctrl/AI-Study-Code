   "source": [
    "scores = [80, 95, 72, 88, 100]\n",
    "\n",
    "total = 0\n",
    "for score in scores:\n",
    "    print(\"점수:\", score)\n",
    "    total += score\n",
    "\n",
    "average = total / len(scores)\n",
    "print(\"평균:\", average)\n",
    "\n",
    "student = {\n",
    "    \"이름\": \"김민수\",\n",
    "    \"점수\": 95,\n",
    "    \"학년\": 2\n",
    "}\n",
    "\n",
    "print(\"학생 이름:\", student[\"이름\"])\n",
    "print(\"학생 점수:\", student[\"점수\"])"
   ]
  }
 ],
